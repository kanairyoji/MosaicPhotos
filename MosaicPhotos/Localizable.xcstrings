      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "端末のアルバム"
          }
        }
      }
    },
    "Diagrams in the architecture note": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設計資料の図"
