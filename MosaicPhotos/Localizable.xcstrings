    "Help" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ヘルプ"
          }
        }
      }
    },
    "How hard the app works in the background to add CLIP embeddings (used for search). Lower is gentler on battery, network and scrolling but slower to finish; higher is faster but heavier. Takes effect on the next batch." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "検索用の CLIP 埋め込みを背景でどれだけ積極的に付けるか。低いほど電池・通信・スクロールに優しいが完了は遅く、高いほど速いが重くなります。次のバッチから反映されます。"
          }
        }
      }
    },
    "How rules work" : {
      "localizations" : {
