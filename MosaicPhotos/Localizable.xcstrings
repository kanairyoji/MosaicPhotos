    "Albums": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバム"
          }
        }
      }
    },
    "Albums & Search": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバムと検索"
          }
        }
      }
    },
    "Albums appear in the “Albums” section on the home screen. They are built from Dropbox photos only, so connect Dropbox and load Cloud first. Runs in the background — regenerate after changing rules.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバムはホーム画面の「アルバム」セクションに表示されます。Dropbox の写真のみから作成されるため、先に Dropbox に接続してクラウドを読み込んでください。バックグラウンドで実行されます。ルール変更後は再生成してください。"
          }
        }
      }
    },
    "All Photos": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての写真"
          }
        }
      }
    },
    "Always": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "常に"
          }
        }
      }
    },
    "Analyzing…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "解析中…"
          }
        }
      }
    },
    "Applies across the whole app: AI indexing, automatic albums, place scanning, Dropbox sync and backup. “While charging” runs only when plugged in and Low Power Mode is off — saves battery. “Always” ignores power state; “Off” pauses all background work. Default: While charging.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリ全体に適用されます：AI 取り込み・自動アルバム・場所スキャン・Dropbox 同期・バックアップ。「充電中のみ」は電源接続中かつ低電力モードがオフのときだけ実行し、電池を節約します。「常に」は電源状態を無視、「オフ」はすべてのバックグラウンド処理を停止します。既定：充電中のみ。"
          }
        }
      }
    },
    "Auto Albums": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動アルバム"
          }
        }
      }
    },
    "Auto-generate in background": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックグラウンドで自動生成"
          }
        }
      }
    },
    "Away-from-home distance": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自宅から離れたとみなす距離"
          }
        }
      }
    },
    "BPE tokenizer algorithm, ported to Swift": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "BPE トークナイザのアルゴリズム（Swift へ移植）"
          }
        }
      }
    },
