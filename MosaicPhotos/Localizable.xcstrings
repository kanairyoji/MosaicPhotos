    "Choose the correct person": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "正しい人物を選ぶ"
          }
        }
      }
    },
    "Clear All Caches": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのキャッシュを消去"
          }
        }
      }
    },
    "Clearing…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "消去中…"
          }
        }
      }
    },
    "Clears all recognition tags (objects, scenes, text, CLIP) and re-analyzes every local photo with the latest model. Metadata (date, place, people) is kept. Runs in the background and may take a while.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認識タグ（物体・シーン・テキスト・CLIP）をすべて消去し、すべての端末写真を最新モデルで再解析します。メタデータ（日付・場所・人物）は保持されます。バックグラウンドで実行され、時間がかかることがあります。"
          }
        }
      }
    },
    "Cloud": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウド"
          }
        }
      }
    },
    "Coarse (5 rows)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "粗い（5行）"
          }
        }
      }
    },
    "Coarse (~5 km)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "粗い（約5 km）"
          }
        }
      }
    },
    "Common pieces": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "よく使う要素"
          }
        }
      }
    },
    "Connected": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続済み"
          }
        }
      }
    },
    "Connecting…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続中…"
          }
        }
      }
    },
    "Consecutive days away from home are merged into one trip (a multi-day trip is not split per day). A larger merge gap tolerates more blank days within a trip; a stay at home starts a new trip.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自宅から離れた連続する日は1つの旅行にまとめます（複数日の旅行を日ごとに分割しません）。許容ギャップを大きくすると旅行中の空白日をより多く許容し、自宅での滞在は新しい旅行の区切りになります。"
          }
        }
      }
    },
    "Core ML model conversion": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Core ML モデルの変換"
          }
        }
      }
    },
    "Create Album": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバムを作成"
          }
        }
      }
    },
    "Default (~2 km)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "標準（約2 km）"
          }
        }
      }
    },
    "Delete Album": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバムを削除"
          }
        }
      }
    },
    "Describe an album — e.g. “Okinawa trips in recent years”.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバムを言葉で指定 — 例：「ここ数年の沖縄旅行」。"
