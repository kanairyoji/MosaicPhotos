        }
      }
    },
    "Developer Options": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "開発者オプション"
          }
        }
      }
    },
    "Device + Dropbox combined": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "端末 + Dropbox を統合"
          }
        }
      }
    },
