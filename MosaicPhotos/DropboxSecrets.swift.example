import Foundation

// テンプレート。このファイルを `DropboxSecrets.swift` にコピーし、自分の Dropbox app key を記入する。
// `DropboxSecrets.swift` は `.gitignore` 対象でコミットされない。
// app key は Dropbox App Console（https://www.dropbox.com/developers/apps）で
// scoped app を作成（`files.content.read` / `files.content.write`）して取得する。
enum DropboxSecrets {
    static let appKey = "YOUR_DROPBOX_APP_KEY"
}
