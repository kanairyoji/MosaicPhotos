{
  "sourceLanguage": "en",
  "strings": {
    "Activity Indicator": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティビティ表示"
          }
        }
      }
    },
    "Cache Limits": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッシュ上限"
          }
        }
      }
    },
    "Cancel": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャンセル"
          }
        }
      }
    },
    "Connect to Dropbox": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Dropbox に接続"
          }
        }
      }
    },
    "Connected": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続済み"
          }
        }
      }
    },
    "Connecting...": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続中..."
          }
        }
      }
    },
    "Disconnect": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "切断"
          }
        }
      }
    },
    "Error": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エラー"
          }
        }
      }
    },
    "Full image limit": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フル画像上限"
          }
        }
      }
    },
    "How many thumbnail batches Dropbox fetches at once (%lld–%lld). Higher is faster when many thumbnails are visible, but too high may hit Dropbox rate limits. Default is %lld.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Dropbox がサムネイルを同時に取得するバッチ数（%1$lld〜%2$lld）。多いほど大量のサムネイル表示が速くなりますが、多すぎると Dropbox のレート制限にかかることがあります。既定は %3$lld。"
          }
        }
      }
    },
    "Not connected": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未接続"
          }
        }
      }
    },
    "Parallel downloads": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "並列ダウンロード数"
          }
        }
      }
    },
    "Show activity bar": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティビティバーを表示"
          }
        }
      }
    },
    "Shows a small bar at the top of the screen with live Dropbox activity: parallel thumbnail download slots and the prefetch queue, plus sync, full-image download and backup upload. Useful to see when Dropbox is busy.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面最上部に Dropbox の稼働状況を小さなバーで表示します：サムネイルの並列ダウンロードスロットと先読みキュー、同期・フル画像ダウンロード・バックアップアップロード。Dropbox が忙しいかどうかの確認に便利です。"
          }
        }
      }
    },
    "Status": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステータス"
          }
        }
      }
    },
    "Thumbnail Performance": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サムネイル性能"
          }
        }
      }
    },
    "Thumbnail limit": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サムネイル上限"
          }
        }
      }
    },
    "Unable to display.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "表示できません。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
