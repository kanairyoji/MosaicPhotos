    "Connect to Dropbox" : { "localizations" : { "ja" : { "stringUnit" : { "state" : "translated", "value" : "Dropbox に接続" } } } },
    "Cancel" : { "localizations" : { "ja" : { "stringUnit" : { "state" : "translated", "value" : "キャンセル" } } } },
