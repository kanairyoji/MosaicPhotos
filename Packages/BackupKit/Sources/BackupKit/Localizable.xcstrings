{
  "sourceLanguage": "en",
  "strings": {
    "%lld": {
      "comment": "A number.",
      "isCommentAutoGenerated": true
    },
    "%lld uploaded · %lld already backed up": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld枚アップロード · %2$lld枚はバックアップ済み"
          }
        }
      }
    },
    "10": {
      "comment": "A label for a 10-photo upload limit.",
      "isCommentAutoGenerated": true
    },
    "100": {
      "comment": "A label for a 100-photo upload limit.",
      "isCommentAutoGenerated": true
    },
    "50": {
      "comment": "A label for a 50-photo option in the backup limit picker.",
      "isCommentAutoGenerated": true
    },
    "500": {
      "comment": "A label for a 500-photo-limit option.",
      "isCommentAutoGenerated": true
    },
    "Back Up Now": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今すぐバックアップ"
          }
        }
      }
    },
    "Backup": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップ"
          }
        }
      }
    },
    "Backup Destination": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップ先"
          }
        }
      }
    },
    "Backup cancelled.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップを中止しました。"
          }
        }
      }
    },
    "Backup records": {
      "comment": "A label for the number of backup records.",
      "isCommentAutoGenerated": true
    },
    "Backup — Folder Check": {
      "comment": "A section that checks the Dropbox folder for the app.",
      "isCommentAutoGenerated": true
    },
    "Backup — Local Library": {
      "comment": "A section in the backup debug section that shows the number of people, albums, and favorites in the local Photos library.",
      "isCommentAutoGenerated": true
    },
    "Backup — Log": {
      "comment": "A section in the backup debug section that shows the log of backup events.",
      "isCommentAutoGenerated": true
    },
    "Backup — Metadata": {
      "comment": "A section in the backup debug section that shows the number of backed-up entries, unique people, unique albums, and favorites.",
      "isCommentAutoGenerated": true
    },
    "Backup — Progress": {
      "comment": "A section in the backup debug section that shows the backup progress.",
      "isCommentAutoGenerated": true
    },
    "Backup — Records (Local DB)": {
      "comment": "A section in the backup debug section that shows the number of backed-up photos and albums.",
      "isCommentAutoGenerated": true
    },
    "Cancel Backup": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップを中止"
          }
        }
      }
    },
    "Check Folder": {
      "comment": "A button that checks the Dropbox folder.",
      "isCommentAutoGenerated": true
    },
    "Check candidates (nothing is deleted)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "候補を確認（何も削除されません）"
          }
        }
      }
    },
    "Checking…": {
      "comment": "A label displayed while Dropbox is checking the folder.",
      "isCommentAutoGenerated": true
    },
    "Clear Upload Progress": {
      "comment": "A button that clears the upload progress of a backup.",
      "isCommentAutoGenerated": true
    },
    "Delete %d photo(s) from this device": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 枚をこの端末から削除"
          }
        }
      }
    },
    "Deleted %d photo(s), skipped %d.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 枚を削除、%d 枚をスキップしました。"
          }
        }
      }
    },
    "Deleting…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除中…"
          }
        }
      }
    },
    "Deletion asks for system confirmation and can be undone from Recently Deleted for 30 days.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除時はシステムの確認ダイアログが表示され、30 日間は「最近削除した項目」から戻せます。"
          }
        }
      }
    },
    "Deletion is disabled. Enable it in Developer Options to delete for real.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実削除は無効です。実際に削除するには Developer Options で有効にしてください。"
          }
        }
      }
    },
    "Destination": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存先"
          }
        }
      }
    },
    "Dropbox Folder": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Dropbox フォルダー"
          }
        }
      }
    },
    "Dropbox is not connected. Connect from Settings → Dropbox.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Dropbox に未接続です。設定 → Dropbox から接続してください。"
          }
        }
      }
    },
    "Folder": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォルダー"
          }
        }
      }
    },
    "Folder found": {
      "comment": "A label indicating that a folder was found at the expected path.",
      "isCommentAutoGenerated": true
    },
    "Last result": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回の結果"
          }
        }
      }
    },
    "Loading photo library…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真ライブラリを読み込み中…"
          }
        }
      }
    },
    "Loading…": {
      "comment": "A placeholder text displayed when loading the backup records.",
      "isCommentAutoGenerated": true
    },
    "Maximum number of photos uploaded in a single backup run.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1回のバックアップでアップロードする写真の最大数。"
          }
        }
      }
    },
    "Metadata path": {
      "comment": "The path to the metadata file.",
      "isCommentAutoGenerated": true
    },
    "No backup": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップしない"
          }
        }
      }
    },
    "No backup metadata loaded.": {
      "comment": "A message displayed when there is no backup metadata to display.",
      "isCommentAutoGenerated": true
    },
    "No photos passed verification.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検証に合格した写真はありません。"
          }
        }
      }
    },
    "No records yet. Run a backup first.": {
      "comment": "A message displayed when there are no backup records yet.",
      "isCommentAutoGenerated": true
    },
    "Not found — will be created": {
      "comment": "A label that indicates that a folder is not found but will be created.",
      "isCommentAutoGenerated": true
    },
    "Offload": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフロード"
          }
        }
      }
    },
    "Offload (free up device storage)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフロード（端末の空き容量を増やす）"
          }
        }
      }
    },
    "Offload removes photos from this device after verifying that an identical copy exists in Dropbox (content hash match). Deleted photos remain in Recently Deleted for 30 days.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフロードは、同一の内容（content hash 一致）が Dropbox に実在することを検証してから、この端末の写真を削除します。削除した写真は 30 日間「最近削除した項目」に残ります。"
          }
        }
      }
    },
    "Path is a file, not a folder": {
      "comment": "A warning message when the backup path is a file instead of a folder.",
      "isCommentAutoGenerated": true
    },
    "Per run": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1回あたり"
          }
        }
      }
    },
    "Photos backed up but none belong to a user-created album.": {
      "comment": "A message displayed when a user has backed up photos but none of them belong to a user-created album.",
      "isCommentAutoGenerated": true
    },
    "Photos per run": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1 回あたりの枚数"
          }
        }
      }
    },
    "Photos will be backed up to this folder in your Dropbox. The folder will be created if it doesn't exist.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真は Dropbox のこのフォルダーにバックアップされます。フォルダーが無ければ作成されます。"
          }
        }
      }
    },
    "Preview which backed-up photos could be safely removed from this device.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックアップ済みの写真のうち、安全に端末から削除できるものを確認できます。"
          }
        }
      }
    },
    "Reading albums and people…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバムと人物を読み込み中…"
          }
        }
      }
    },
    "Ready to offload (verified)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフロード可能（検証済み）"
          }
        }
      }
    },
    "Requesting photo library access…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真ライブラリへのアクセスを要求中…"
          }
        }
      }
    },
    "Saving metadata…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メタデータを保存中…"
          }
        }
      }
    },
    "Skipped (kept on device)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スキップ（端末に保持）"
          }
        }
      }
    },
    "Unlimited": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無制限"
          }
        }
      }
    },
    "Upload Limit": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アップロード上限"
          }
        }
      }
    },
    "Uploaded IDs": {
      "comment": "A label for the number of uploaded photo IDs.",
      "isCommentAutoGenerated": true
    },
    "Uploading %lld of %lld": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アップロード中 %1$lld / %2$lld"
          }
        }
      }
    },
    "Verifying…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検証中…"
          }
        }
      }
    }
  },
  "version": "1.1"
